# Use "local" while developing. Use "supabase" in production.
SUBMISSION_STORAGE=local

# Required to access /admin. Replace this with a strong private password.
ADMIN_PASSWORD=replace-with-a-strong-private-password

# Required for Supabase storage. Vercel uses Supabase automatically.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
