# Use "local" while developing. Use "supabase" in production.
SUBMISSION_STORAGE=local

# Required to access /admin. Replace this with a strong private password.
ADMIN_PASSWORD=replace-with-a-strong-private-password

# Required when SUBMISSION_STORAGE=supabase.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-server-only-secret-key
